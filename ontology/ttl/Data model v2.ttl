virgo:concernPerbankan rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain virgo:Talent ;
                       rdfs:range xsd:boolean ;
                       rdfs:label "concernPerbankan" .



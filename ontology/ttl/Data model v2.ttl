###  http://padepokan79.com/ontology/skill#Placement
virgo:Placement rdf:type owl:Class ;
                rdfs:label "Placement" .


###  http://padepokan79.com/ontology/skill#Project
virgo:Project rdf:type owl:Class ;
              rdfs:label "Project" .


###  http://padepokan79.com/ontology/skill#Talent
virgo:Talent rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty virgo:hasSkill ;
                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                   owl:onClass virgo:root
                                 ] ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty virgo:hasSkill ;
                               owl:allValuesFrom virgo:root
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty virgo:nip ;
                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:string
                             ] ;
             rdfs:label "Talent" .



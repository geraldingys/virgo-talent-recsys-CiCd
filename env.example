# ─── FastAPI ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ─── Neo4j Aura ──────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=<username>
NEO4J_PASSWORD=<password>
NEO4J_DATABASE=<database-name>

# ─── Ollama — Remote server PT P79 ────────────────────────
# Ganti dengan URL dan token yang diberikan PT P79
OLLAMA_BASE_URL=https://<url-server-p79>
OLLAMA_MODEL=qwen3:8b
# Token dikirim sebagai: Authorization: Bearer <token>
OLLAMA_API_TOKEN=your_bearer_token_here

# ─── Virgo Database (read-only access ke DB existing) ─────
VIRGO_DB_HOST=localhost
VIRGO_DB_PORT=5432
VIRGO_DB_NAME=virgo
VIRGO_DB_USER=readonly_user
VIRGO_DB_PASSWORD=changeme123
